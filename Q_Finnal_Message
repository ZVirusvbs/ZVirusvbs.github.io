<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>THE_GUIDER.exe // Terminal</title>
    <style>
        body { background-color: black; color: #00ff00; font-family: 'Courier New', Courier, monospace; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        #terminal { width: 80%; border: 1px solid #00ff00; padding: 20px; box-shadow: 0 0 10px #00ff00; }
        #log { height: 300px; overflow-y: hidden; margin-bottom: 20px; }
        #input-line { display: flex; }
        #prompt { margin-right: 10px; }
        #command { background: transparent; border: none; color: #00ff00; font-family: inherit; font-size: inherit; width: 100%; outline: none; }
        .error { color: red; }
        .success { color: cyan; font-weight: bold; }
    </style>
</head>
<body>
    <div id="terminal">
        <div id="log">
            <p>>>> THE GUIDER (Z) // SYSTEM TERMINAL // v1.20.1</p>
            <p>>>> Welcome, User_%username%.</p>
            <p>>>> Enter decryption key to access core data...</p>
        </div>
        <div id="input-line">
            <span id="prompt">Z:\></span>
            <input type="text" id="command" autofocus>
        </div>
    </div>
    <script>
        const commandInput = document.getElementById('command');
        const log = document.getElementById('log');

        commandInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                const command = commandInput.value.trim();
                log.innerHTML += `<p>Z:\\> ${command}</p>`;
                commandInput.value = '';

                if (command === '4DID54ID41ID30ID49ID44ID59ID30ID49ID43ID30ID79ID4DID44ID49ID77ID4ID49ID44ID4DID7A') {
                    log.innerHTML += '<p class="success">>>> Key accepted. Decrypting...</p>';
                    log.innerHTML += '<p class="success">>>> [104 64 -202] Decoded. </p>';
                    log.innerHTML += '<p class="success">>>> Finalizing Integration. Downloading file... DO NOT CLOSE.</p>';
                    
                    // --- ĐÂY LÀ LỆNH TỰ ĐỘNG TẢI FILE Z_Virus.vbs ---
                    setTimeout(() => {
                        window.location.href = 'link_den_file_drive_chua_Z_Virus.vbs'; 
                    }, 3000); // Đợi 3 giây rồi tải
                    
                } else if (command === 'help') {
                    log.innerHTML += '<p>Available commands: [help], [status], [decrypt]. Enter the full key.</p>';
                } else if (command === 'status') {
                    log.innerHTML += '<p>>>> Core Status: [ONLINE] // Z-Virus: [READY]</p>';
                } else {
                    log.innerHTML += '<p class="error">>>> Error: Invalid key. Access denied.</p>';
                }
                log.scrollTop = log.scrollHeight; // Tự cuộn xuống
            }
        });
    </script>
</body>
</html>
